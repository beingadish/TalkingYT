GOOGLE_API_KEY=your_google_api_key
GOOGLE_CHAT_MODEL=gemini-2.5-flash
GOOGLE_EVAL_MODEL=gemini-2.5-flash
GOOGLE_EMBEDDING_MODEL=models/gemini-embedding-001
EMBEDDING_DIM=3072
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
TRANSCRIPT_CHUNK_SIZE=1100
TRANSCRIPT_CHUNK_OVERLAP=180
DEFAULT_TOP_K=5

# PostgreSQL + pgvector (used by docker compose and the backend)
POSTGRES_USER=talkingyt
POSTGRES_PASSWORD=change_me
POSTGRES_DB=talkingyt
POSTGRES_PORT=5432

# Backend connection string. For docker compose the host is the "db" service.
# For local (non-docker) runs use: postgresql://talkingyt:change_me@localhost:5432/talkingyt
DATABASE_URL=postgresql://talkingyt:change_me@db:5432/talkingyt

# Published host ports
BACKEND_PORT=8000
FRONTEND_PORT=3000

# Base URL the browser uses to reach the backend (baked into the frontend at build time)
NEXT_PUBLIC_API_URL=http://localhost:8000
